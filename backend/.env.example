# WearImpact Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file to version control.

# ---------------------------------------------------------------------------
# Google Maps Platform
# ---------------------------------------------------------------------------
# API key with Places API enabled (Nearby Search + Place Details)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Outbound timeout for Google Places API calls (seconds)
GOOGLE_PLACES_TIMEOUT_SECONDS=6

# ---------------------------------------------------------------------------
# Redis Cache (Epic 1 Step 4 — Place Details)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# TTL for cached place details (seconds) — default 24 hours
PLACE_DETAILS_CACHE_TTL=86400

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
